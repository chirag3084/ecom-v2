# Copy this file to .env and fill in real values.
# .env is loaded automatically (see settings.py / python-dotenv).

# Django
# Required in production. In DEBUG mode a throwaway dev key is used if this
# is left unset, so the project still runs locally without it.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave DB_ENGINE unset (or sqlite3, as below) to use local SQLite - no
# further setup needed. Switch to Postgres by setting DB_ENGINE and filling
# in the rest.
DB_ENGINE=django.db.backends.sqlite3
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=postgres
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
# DB_HOST=your-db-host
# DB_PORT=5432

# Celery / Redis (only needed if you run the Celery worker)
CELERY_BROKER_URL=redis://localhost:6379/0

# Razorpay (needed for the checkout/payment flow)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
